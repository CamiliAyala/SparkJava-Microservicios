<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Pedidos Now - Menú Principal</title>
    <style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #fdfdfd; /* Blanco muy claro */
    }

    .navbar {
        background-color: #1e90ff; /* Azul fuerte */
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
    }

    .navbar h1 {
        margin: 0;
        font-size: 1.8rem;
    }

    .menu {
        display: flex;
        gap: 1.5rem;
    }

    .menu a {
        color: white;
        text-decoration: none;
        font-weight: bold;
        font-size: 1rem;
        transition: color 0.2s;
    }

    .menu a:hover {
        color: #b0e0e6; /* Azul celeste claro al pasar el mouse */
    }

    .content {
        padding: 2rem;
    }

    .card {
        background-color: #ffffff;
        padding: 2rem;
        margin-bottom: 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 8px rgba(30, 144, 255, 0.2); /* Sombra azul suave */
        text-align: center;
    }

    .pedido-card {
        background-color: #f0f8ff; /* Azul muy claro */
        border: 1px solid #add8e6;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(30, 144, 255, 0.1);
    }

    .pedido-card h2 {
        color: #1e90ff; /* Azul fuerte */
        margin-top: 0;
    }

    .pedido-card ul {
        list-style-type: disc;
        padding-left: 1.5rem;
        margin: 1rem 0;
        text-align: left;
    }

    .pedido-card strong {
        display: block;
        margin-top: 1rem;
        color: #4682b4; /* Azul acero */
        font-size: 1.1rem;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 2rem;
    }

    th, td {
        border: 1px solid #add8e6;
        padding: 12px;
        text-align: center;
    }

    th {
        background-color: #e0ffff; /* Azul claro */
        color: #1e90ff; /* Azul fuerte */
        font-weight: bold;
    }

    td {
        background-color: #f0f8ff; /* Azul muy claro */
    }

    .pedido-actions {
        margin-top: 1rem;
    }

    .pedido-actions form {
        display: inline-block;
        margin-right: 0.5rem;
    }

    .btn-accion {
        background-color: #1e90ff; /* Azul fuerte */
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        font-size: 14px;
        transition: background-color 0.2s ease;
    }

    .btn-accion:hover {
        background-color: #4682b4; /* Azul acero */
    }
</style>

</head>
<body>

<div class="navbar">
    <h1>Pedidos Now - Versión Repartidores 🏍️️️</h1>
    <div class="menu">
        <a href="/api/inicio">Inicio</a>
        <a href="/api/repartidor/pedidosVigentes">Pedidos Vigentes</a>
        <a href="/api/repartidor/pedidosAceptados">Pedidos Aceptados</a>
        <a href="/api/repartidor/pedidosEntregados">Pedidos Entregados</a>
        <a href="/logout">Salir</a>
    </div>
</div>

<div class="content">
    <div class="card">
        <h2>¡Bienvenido/a $user!</h2>
        #if($accion == "inicio")
        <p>Selecciona una opción del menú para comenzar a utilizar la plataforma.</p>
        #end
    </div>

    #if($accion == "getPedidosVigentes")
        #if($pedidosAgrupados.size() > 0)
        <p><strong>Pedidos Vigentes a tomar</strong></p>
            #foreach($pedidoId in $pedidosAgrupados.keySet())
            #set($platos = $pedidosAgrupados.get($pedidoId))
            #set($primerPlato = $platos.get(0))
            <div class="pedido-card">
                <h2>Pedido ID: $pedidoId</h2>
                <p><strong>Usuario:</strong> $primerPlato.user_name</p>
                <p><strong>Estado Usuario:</strong> $primerPlato.user_estado</p>
                <p><strong>Estado Restaurante:</strong> $primerPlato.restaurante_estado</p>
                <p><strong>Estado Repartidor:</strong> $primerPlato.repartidor_estado</p>
                <ul>
                    #foreach($plato in $platos)
                    <li>Plato: $plato.nombre_plato - Cantidad: $plato.cantidad - Subtotal: $plato.subtotal</li>
                    #end
                </ul>
                <strong>Total del Pedido: $primerPlato.total_pedido</strong>
                <div class="pedido-actions">
                    <form method="post" action="/pedido/aceptar">
                        <input type="hidden" name="pedidoId" value="$pedidoId" />
                        <button class="btn-accion" type="submit">Aceptar</button>
                    </form>
                    <form method="post" action="/pedido/rechazar">
                        <input type="hidden" name="pedidoId" value="$pedidoId" />
                        <button class="btn-accion" type="submit">Rechazar</button>
                    </form>
                </div>
            </div>
            #end
        #end
    #end
    #if($accion == "getPedidosAceptados")
        #if($pedidosAgrupados.size() > 0)
        <p><strong>Pedidos en Camino</strong></p>
            #foreach($pedidoId in $pedidosAgrupados.keySet())
            #set($platos = $pedidosAgrupados.get($pedidoId))
            #set($primerPlato = $platos.get(0))
            <div class="pedido-card">
                <h2>Pedido ID: $pedidoId</h2>
                <p><strong>Usuario:</strong> $primerPlato.user_name</p>
                <p><strong>Estado Usuario:</strong> $primerPlato.user_estado</p>
                <p><strong>Estado Restaurante:</strong> $primerPlato.restaurante_estado</p>
                <p><strong>Estado Repartidor:</strong> $primerPlato.repartidor_estado</p>
                <ul>
                    #foreach($plato in $platos)
                    <li>Plato: $plato.nombre_plato - Cantidad: $plato.cantidad - Subtotal: $plato.subtotal</li>
                    #end
                </ul>
                <strong>Total del Pedido: $primerPlato.total_pedido</strong>
                <div class="pedido-actions">
                    <form method="post" action="/pedido/entregado">
                        <input type="hidden" name="pedidoId" value="$pedidoId" />
                        <button class="btn-accion" type="submit">Entregado</button>
                    </form>
                </div>
            </div>
            #end
        #end
    #end
    #if($accion == "getPedidosEntregados")
        #if($pedidosAgrupados.size() > 0)
        <p><strong>Pedidos Entregados</strong></p>
            #foreach($pedidoId in $pedidosAgrupados.keySet())
            #set($platos = $pedidosAgrupados.get($pedidoId))
            #set($primerPlato = $platos.get(0))
            <div class="pedido-card">
                <h2>Pedido ID: $pedidoId</h2>
                <p><strong>Usuario:</strong> $primerPlato.user_name</p>
                <p><strong>Estado Usuario:</strong> $primerPlato.user_estado</p>
                <p><strong>Estado Restaurante:</strong> $primerPlato.restaurante_estado</p>
                <p><strong>Estado Repartidor:</strong> $primerPlato.repartidor_estado</p>
                <ul>
                    #foreach($plato in $platos)
                    <li>Plato: $plato.nombre_plato - Cantidad: $plato.cantidad - Subtotal: $plato.subtotal</li>
                    #end
                </ul>
                <strong>Total del Pedido: $primerPlato.total_pedido</strong>
            </div>
            #end
        #end
    #end
</div>

</body>
</html>
